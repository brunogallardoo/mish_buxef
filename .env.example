# =============================================================================
# CampusRadar - Variables de entorno (ejemplo)
# =============================================================================
# Copia este archivo como `.env` y ajusta los valores.
# El `.env` real NUNCA debe versionarse (ya está en .gitignore).
# En despliegue (Render/Railway/Docker) define estas variables en el panel del
# servicio en lugar de subir un archivo .env.
# =============================================================================

# Clave secreta para firmar los JWT. Genera una propia y larga, por ejemplo:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=cambia-esta-clave-por-una-aleatoria-larga-y-secreta

# Algoritmo de firma del JWT (por defecto HS256).
ALGORITHM=HS256

# Minutos de validez del token de acceso (por defecto 480 = 8 horas).
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Base de datos. Opciones:
#   - SQLite local (ruta de archivo):  campusradar.db
#   - SQLite (URL absoluta):           sqlite:////app/data/campusradar.db
#   - PostgreSQL:                      postgresql+psycopg2://usuario:clave@host:5432/campusradar
DATABASE_URL=campusradar.db
